{
  "name": "rumah-nf3",
  "version": "0.1.0",
  "private": true,
  "description": "Rumah NF3 — Internal Command Center & ERP Lite (portal induk untuk Nusa Food Group & Nusa Fishing).",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:phase0": "vitest run lib/outlet-identity.test.ts lib/auth-guard.test.ts lib/api-auth.test.ts lib/audit-log.test.ts lib/persistence-mismatch.test.ts lib/kds-discrepancy.test.ts lib/kds-service-phase0.test.ts lib/phase0-baseline-characterization.test.ts",
    "test:metrics": "vitest run lib/metrics.test.ts",
    "test:inventory": "vitest run lib/inventory-metrics.test.ts lib/inventory-validate.test.ts lib/kds-closing-service.test.ts",
    "test:inventory-e2e": "node --env-file=.env.local scripts/test-inventory-e2e.mjs",
    "test:waste-form-flow": "node --env-file=.env.local scripts/test-waste-form-flow.mjs",
    "migrate:inventory-extra": "node --env-file=.env.local scripts/migrate-inventory-extra.mjs",
    "seed:opname-awal": "node --env-file=.env.local scripts/seed-opname-awal.mjs",
    "check:prod": "node --env-file=.env.local scripts/check-prod-env.mjs",
    "verify:deploy": "node --env-file=.env.local scripts/verify-deploy.mjs",
    "import:inventory": "node --env-file=.env.local scripts/import-inventory-csv.mjs",
    "convert:barang-masuk": "node scripts/convert-barang-masuk-template.mjs",
    "condition:inventory": "node --env-file=.env.local scripts/condition-inventory.mjs",
    "sync:vercel-env": "node scripts/sync-vercel-env.mjs",
    "smoke:pos": "node scripts/pos-smoke-uat.mjs",
    "smoke:pos-uat": "node scripts/pos-production-uat.mjs",
    "seed:admin": "node --env-file=.env.local scripts/seed-super-admin.mjs",
    "seed:loyalty-payroll": "node --env-file=.env.local scripts/seed-loyalty-payroll.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "bcryptjs": "^3.0.3",
    "lucide-react": "^0.468.0",
    "next": "14.2.15",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.17.6",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.15",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  }
}
