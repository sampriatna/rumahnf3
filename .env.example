# Rumah NF3 — Command Center
# Salin file ini menjadi .env.local lalu isi nilainya. JANGAN commit .env.local.

# --- Supabase (project BARU khusus Command Center, schema nf3) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# UUID bisnis Catatin (public.app_state.business_id) — owner /reports/owner baca dailyReports kasir.
# Satu Supabase: kasir submit & owner lihat baris app_state yang sama (RLS business_members).
# NF3_CATATIN_BUSINESS_ID=

# Koneksi Postgres langsung (opsional) — untuk npm run migrate:inventory-extra tanpa SQL Editor.
# Supabase → Project Settings → Database → Connection string (URI, mode Transaction pooler).
# SUPABASE_DB_URL=postgresql://postgres.[project-ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres

# --- Inventory (Supabase Sheets model: master_bahan, barang_masuk, transfer_stok, dll.) ---
# dummy | sheets | supabase — production: supabase
INVENTORY_SOURCE=supabase

# --- Session (cookie HMAC). WAJIB di production — tanpa ini cookie bisa dipalsukan.
# Buat string acak panjang (min. 32 karakter). Dev: boleh kosong (fallback insecure).
SESSION_SECRET=

# --- URL publik (production) ---
NEXT_PUBLIC_APP_URL=https://rumah.nf3.company
NEXT_PUBLIC_POS_URL=https://pos.nf3.company
NEXT_PUBLIC_KDS_URL=https://kds.nf3.company
NEXT_PUBLIC_STAFF_URL=https://staff.nf3.company
# Cookie session lintas subdomain (*.nf3.company). Opsional jika APP_URL sudah nf3.company.
SESSION_COOKIE_DOMAIN=.nf3.company

# --- Link-out ke Task Dashboard existing (TIDAK diubah oleh app ini) ---
NEXT_PUBLIC_TASK_DASHBOARD_URL=https://task.nf3.company
# Integrasi ringkasan task telat (server-only, opsional sampai endpoint Task siap):
# URL otomatis dari NEXT_PUBLIC_TASK_DASHBOARD_URL + /api/integrations/nf3/summary
# TASK_DASHBOARD_API_URL=https://task.nf3.company/api/integrations/nf3/summary
# KEY opsional — harus sama dengan NF3_INTEGRATION_API_KEY di Task Dashboard:
# TASK_DASHBOARD_API_KEY=

# --- GAWE / E-Presensi GPS (absensi harian, Laravel di squadnf3.id) ---
NEXT_PUBLIC_ATTENDANCE_URL=https://squadnf3.id

# --- Payroll / Loyalty Supabase (jalankan supabase/loyalty-app.sql + payroll-app.sql) ---
# npm run seed:loyalty-payroll

# --- WhatsApp notification provider (Fonnte / generic JSON POST) ---
# fonnte: set WA_PROVIDER=fonnte, URL=https://api.fonnte.com/send, TOKEN= dari dashboard Fonnte
# generic: POST JSON { phone/target, message/text } dengan Authorization: Bearer TOKEN
WA_PROVIDER=fonnte
WA_PROVIDER_URL=https://api.fonnte.com/send
WA_PROVIDER_TOKEN=
# Nomor tujuan diambil dari profil user (08xx → 628xx otomatis). Kosongkan token = mode log saja.

# --- Cron Vercel: jam sepi (UTC schedule di vercel.json = 09–21 WIB) ---
# WAJIB di production. Vercel Cron otomatis kirim Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# --- PHASE 0 feature flags (staging rollout — lihat docs/PHASE_0_EXIT_GATE.md) ---
# Default production: semua false kecuali CANONICAL_OUTLET_IDENTITY (true di kode).
# Tahap A staging (aman): AUDIT + PERSISTENCE_MISMATCH ON
# NF3_FF_CANONICAL_OUTLET_IDENTITY=true
# NF3_FF_AUDIT_LOG_FOUNDATION=true
# NF3_FF_PERSISTENCE_MISMATCH_LOG=true
# Tahap B staging: setelah Tahap A lulus
# NF3_FF_AUTHORIZATION_PIPELINE=true
# Tahap C staging (opsional): KDS canonical writer
# NF3_FF_KDS_CANONICAL_BOARD_WRITER=true
# JANGAN aktifkan tanpa approval: NF3_FF_DUAL_WRITE_ENABLED / NF3_FF_DUAL_WRITE_STRICT

# --- UI rollout (incremental — lihat docs/UI_IMPLEMENTATION_PLAN.md) ---
# NF3_FF_APP_SHELL_V1=true
# NF3_FF_POS_LAYOUT_V2=true
# NF3_FF_POS_DRAWER_NAV_V1=true
# NF3_FF_ORDERS_PAGE_V1=true
# NF3_FF_CHECKER_READ_V1=true
# NF3_FF_KDS_SUMMARY_V1=true
# NF3_FF_UI_OPS_V1=true
# NF3_FF_UI_INVENTORY_V1=true

# --- Inventory scripts (dev) ---
# npm run migrate:inventory-extra   # supplier + view saldo (butuh SUPABASE_DB_URL atau supabase login)
# npm run test:inventory-e2e        # uji mutasi waste → saldo
# npm run test:waste-form-flow      # uji alur form waste staff
# npm run condition:inventory       # siapkan CSV dari template
# npm run import:inventory          # import CSV ke Supabase
